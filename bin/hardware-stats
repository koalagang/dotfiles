#!/usr/bin/bash

echo "Current memory usage:"
free -h | awk '/^Mem:/ {print $3 "/" $2}'
echo "HIGH: 10Gi"
echo "CRITICAL: 13.5Gi"
echo ""

echo "Most memory intensive programs (%):"
ps axch -o cmd:15,%mem --sort=-%mem | head
echo ""

echo "Current CPU temperature:"
sensors | awk '/^temp1/ {print $2}'
echo "HIGH: +70°C"
echo "CRITICAL: +80°C"
echo ""

echo "Most CPU intensive programs (%):"
ps axch -o cmd:15,%cpu --sort=-%cpu | head
echo ""

neofetch # My neofetch config gives hardware related info

# I also plan on making this script automatically shutdown the computer if anything becomes critical.
