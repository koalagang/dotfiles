#------KOALA'S KEYBINDINGS

# Power options
ctrl + alt + {x,r,s}
	loginctl {poweroff, reboot, suspend}

# Lockscreen
ctrl + alt + l
    slock

# Dmenu
mod4 + d ; {r,c,u,k,l,s,m}
    {dmenu_run,dcalc,dmenuunicode,dmkill,dmlogout,dmsearch,maimpick}

# Terminal
mod4 + Return
    $TERMINAL

# Applications
mod4 + alt + {k,s,l,m,v,f,g,p,a,d,w,b}
	{keepassxc,signal-desktop,lutris,multimc,steam,spacefm,gimp,lollypop,anki,discord,$BROWSER,brave}

# Media controls
{XF86AudioNext,XF86AudioPrev,XF86AudioPlay}
    playerctl {next,previous,play-pause}

# Volume controls
{XF86AudioMute,XF86AudioLowerVolume,XF86AudioRaiseVolume}
    amixer -D pulse sset Master {toggle -q,5%-,5%+}

# Close window (ps. 'p' is used because 'k' is already taken)
mod4 + ctrl + {c,p}
    xdo {close,kill && notify-send '$(xdotool getactivewindow getwindowname)' 'has been killed.'}

# Restart sxhkd
mod4 + b
	notify-send "Refreshed sxhkd bindings." && killall sxhkd && sxhkd &

# Keyboard layouts
mod4 + {u,n,g}
    setxkbmap -layout {us,no,gb}
