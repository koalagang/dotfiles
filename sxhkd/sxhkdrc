#------KOALA'S KEYBINDINGS

#---System

# Shutdown
super + shift + x
	shutdown now

# Reboot
super + shift + r
	reboot

# Suspend
super + shift + s
	systemctl suspend

# Lock
super + shift + l
	xdg-screensaver lock


#---Applications

# Launching main applications
super + alt + {h,k,s,l,m,v,f,g,p,a,d,n,c}
	{$TERM -e htop, keepassxc, signal-desktop, lutris, multimc, steam, spacefm, gimp, lollypop, anki, ~/Desktop/.discord/discord, ~/Desktop/.netflix/netflix, ~/Desktop/.crunchyroll/crunchyroll}

# Brave Profiles
super + alt + {w,b}
    {brave --profile-directory="Default", brave --profile-directory="Profile 2"}

# Buku
ctrl + ~g
    alacritty -e buku -w

#---Screenshots

# Screenshot selected window or area with a 2 second delay and copy to clipboard
super + alt + {u}
	maim -s -d 2 | xclip -selection clipboard -t image/png

# Screenshot selected window or area with a 2 second delay and save to ~/Pictures
ctrl + alt + {u}
	maim ~/Pictures/(date).png -u

# Screenshot currently active window and save to ~/Pictures
Print
	maim -i (xdotool getactivewindow) ~/Pictures/(date).png -u


#---Windows

# Kill window
ctrl + shift + k
	notify-send (xdotool getactivewindow getwindowname) "has been killed." && xdo kill

# Close window
ctrl + shift + c
	xdo close

# Minimise current window
ctrl + shift + m
	xdotool getactivewindow windowminimize

# Increase window width
shift + alt + {h,j,k,l}
	xdo resize {-w -9, -h +9, -h -9, -w +9}


#---Misc

# Restart sxhkd
ctrl + alt + {c}
	notify-send "Refreshed sxhkd configs." && kill sxhkd && sxhkd &
