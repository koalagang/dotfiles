#------KOALA'S KEYBINDINGS

#---System

# Shutdown
ctrl + alt + x
	shutdown now

# Reboot
ctrl + alt + r
	reboot

# Suspend
ctrl + alt + s
	systemctl suspend

# Lock
ctrl + alt + l
	xdg-screensaver lock


#---Applications

# Launching main applications
super + alt + {b,h,k,s,l,m,v,f,g,p,a,d,n}
	{brave, alacritty -e htop, keepassxc, signal-desktop, lutris, multimc, steam, spacefm, gimp, lollypop, anki}

# Screenshot selected window or area instantly and copy to clipboard
super + alt + {u}
	maim -s | xclip -selection clipboard -t image/png

# Screenshot selected window or area with a 2 second delay and copy to clipboard
super + ctrl + {u}
	maim -s -d 2 | xclip -selection clipboard -t image/png

# Screenshot selected window or area instantly and save to ~/Pictures
ctrl + alt + {u}
	maim ~/Pictures/(date).png

# Screenshot currently active window and save to ~/Pictures
Print
	maim -i (xdotool getactivewindow) ~/Pictures/(date).png -u


#---Windows

# Kill window
ctrl + shift + k
	xdo kill

# Close window
ctrl + shift + c
	xdo close

# Minimise current window
ctrl + shift + m
	xdotool getactivewindow windowminimize

# Increase window width
shift + alt + {h,j,k,l}
	xdo resize {-w -9, -h +9, -h -9, -w +9}
