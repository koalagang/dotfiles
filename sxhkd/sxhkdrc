#---KOALA'S KEYBINDINGS

# Launch terminal
mod4 + Return
    $TERMINAL

# Power options
ctrl + alt + {x,r,s}
	loginctl {poweroff, reboot, suspend}

# Lockscreen (slock)
ctrl + alt + l
    slock

# Dmenu
mod4 + d ; {r,c,u,k,l,m,s}
    {dmenu_run,pycalcmenu,dmenuunicode,dmkill,dmlogout,magickshot,soundpick}

# Launch applications
mod4 + alt + {k,s,l,m,g,d,w,b}
	{keepassxc,signal-desktop,lutris,/opt/multimc/run.sh,steam,discord,$BROWSER,brave}

# Media controls
{XF86AudioNext,XF86AudioPrev,XF86AudioPlay}
    playerctl {next,previous,play-pause}

# Volume controls
{XF86AudioMute,XF86AudioLowerVolume,XF86AudioRaiseVolume}
    amixer -D pulse sset Master {toggle -q,5%-,5%+}

# Refresh sxhkd bindings
mod4 + ctrl + b
	notify-send "Refreshed sxhkd bindings." && killall sxhkd && sxhkd &

# Keyboard layouts
mod4 + shift + {u,n,g}
    setxkbmap -layout {us,no,gb} && xmodmap -e 'keycode 62 = Escape'

# Take a screenshot (currently active monitor)
Print
    import -window root "$HOME/Pictures/$(date '+%F_%T' | sed -e 's/:/-/g').png"
