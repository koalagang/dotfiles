#!/bin/sh
# Dependencies: dmenu, python
# NOTE: python is not an advanced calculator (in fact it can't even find the square root of n)
# I am not a mathematician and python is good enough for me
# but I recommend `quiche` if you need something more complicated.
equation=$(echo | dmenu -p "Enter equation" | xargs -I % python -c "print(%)")
notify-send "Result" "$equation"
