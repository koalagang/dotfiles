#!/bin/sh

case "$(printf "a selected area (copy)\\ncurrent window (copy)\\nfull screen (copy)\\na selected area (save)\\ncurrent window (save)\\nfull screen (save)" | dmenu -l 6 -p "Screenshot which area?")" in
	"a selected area (copy)") maim -s | xclip -selection clipboard -t image/png ;;
	"current window (copy)") maim -i "$(xdotool getactivewindow)" | xclip -selection clipboard -t image/png ;;
	"full screen (copy)") maim | xclip -selection clipboard -t image/png ;;
    "a selected area (save)") maim -s "$HOME/Pictures/$(date '+%y%m%d-%H%M-%S').png" ;;
    "current window (save)") maim -i "$(xdotool getactivewindow)" "$HOME/Pictures/$(date '+%y%m%d-%H%M-%S').png" ;;
    "full screen (save)") maim "$HOME/Pictures/$(date '+%y%m%d-%H%M-%S').png" ;;
esac
